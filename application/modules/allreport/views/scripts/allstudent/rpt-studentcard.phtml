function getStudentInfo(){
	optionSelect=dijit.byId("optionSelect").get("value");
	if(optionSelect!=2){
		dijit.byId('studentID').attr('value',0);
		dijit.byId('optionSelect').focus();
		return false;
	}
	var url_student = '<?php echo $this->url(array('module'=>'foundation','controller'=>'register','action'=>'getstudentstudyinfo')); ?>';
	studentid = dijit.byId('studentID').get('value');
 	if(studentid==''){
 		alert("Please Select Student");
 		return false;
 	}
	dojo.xhrPost({
 		url:url_student,
 		content:{
 			'study_id':studentid
 			},
 		handleAs:"json",
 		load: function(data) { 
			addRow(data);
 			//dijit.byId('degree').set('value',data.degree);
		},
		error: function(err) {
		}
	});
}
