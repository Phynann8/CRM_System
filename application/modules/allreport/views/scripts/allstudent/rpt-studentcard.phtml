var oldBranch = '<?php echo $this->search['branch_id']?>'
url_getgroup = '<?php echo $this->url(array('module'=>'foundation','controller'=>'group','action'=>'getallgroup'));?>';
function getAllGroupByBranch(){
	dijit.byId('group').reset();
	branch_id = dijit.byId('branch_id').get('value');
	if(branch_id=='' || branch_id==-1){
		var group_store  = getDataStorefromJSON('id','name',<?php print_r(Zend_Json::encode(array()));?> );
		dijit.byId('group').set('store',group_store);  
		dijit.byId('branch_id').focus();
		return false;
	}
	degree = dijit.byId('degree').get('value');
	if(degree=='' || degree==-1){degree ="";}
	grade = dijit.byId('grade').get('value');
	if(grade=='' || grade==-1){grade ="";}
	academic_year = dijit.byId('academic_year').get('value');
	if(academic_year=='' || academic_year==-1){academic_year ="";}
	
	dojo.xhrPost({
		url: url_getgroup,
		content:{
			'branch_id':branch_id,
			'degree':degree,
			'grade':grade,
			'academic_year':academic_year,
			'noaddnew':1,
			'forfilter':1
			},
		handleAs:"json",
		load: function(data) {
		    group_store  = getDataStorefromJSON('id','name', data);
		    dijit.byId('group').set('store',group_store);   
		    if(oldBranch==branch_id){
		    	dijit.byId('group').set('value','<?php echo $this->search['group']?>');  
		    }
		},
		error: function(err) {
		}
	});
}

var url_dept = '<?php echo $this->url(array('module'=>'global','controller'=>'grade','action'=>'get-grade')); ?>';
function getallGrade(){
	getAllGroupByBranch();  
	dept_id = dijit.byId('degree').get('value');
	if(dept_id=='' || dept_id==-1){return false;}
		dojo.xhrPost({
			url:url_dept,
			content:{
				'dept_id':dept_id,
				'noaddnew':1
				},
			handleAs:"json",
			load: function(data) {
				dijit.byId('grade').attr('value','');
				grade_store  = getDataStorefromJSON('id','name', data);
			    dijit.byId('grade').set('store',grade_store); 
			    dijit.byId('grade').attr('value','<?php echo $this->search['grade']?>');  
			},
			error: function(err) {
			}
		});
}

var urlGetStudent = '<?php echo $this->url(array('module'=>'foundation','controller'=>'register','action'=>'getstudentlist')); ?>';
function getAllStudent(){
	var branch_id = dijit.byId('branch_id').get('value');
	if(branch_id==-1 || branch_id=="" ){
		branch_id = 0;
	}
	var studentStore  = getDataStorefromJSON('id','name',<?php print_r(Zend_Json::encode(array()));?> );
	dijit.byId('studentID').set('store',studentStore); 
	
	var academic_year = dijit.byId('academic_year').get('value');
	var group = dijit.byId('group').get('value');
	var degree = dijit.byId('degree').get('value');
	var grade = dijit.byId('grade').get('value');
	
	dojo.xhrPost({
		url: urlGetStudent,
		content:{
			'branchId'		:branch_id,
			'academicYear' :academic_year,
			'groupId'			:group,
			'degree'		:degree,
			'grade'			:grade,
			'joinGroup'		:1,
			'activeStudent'		:1,
			},
		handleAs:"json",
		load: function(data) {
			dijit.byId('studentID').attr('value','');
			var studentStore  = getDataStorefromJSON('id','name', data);
			dijit.byId('studentID').set('store',studentStore); 
		},
		error: function(err) {
		}
	});
}

var urlGetCard = '<?php echo $this->url(array('module'=>'setting','controller'=>'cardmg','action'=>'allcardst')); ?>';
function getAllCardType(){
	var branch_id = dijit.byId('branch_id').get('value');
	if(branch_id==-1 || branch_id=="" ){
		branch_id = 0;
	}
	var degree = dijit.byId('degree').get('value');
	var studentStore  = getDataStorefromJSON('id','name',<?php print_r(Zend_Json::encode(array()));?> );
	dijit.byId('studentID').set('store',studentStore); 
	dojo.xhrPost({
		url: urlGetCard,
		content:{
			'branchId'		:branch_id,
			'degree'		:degree,
