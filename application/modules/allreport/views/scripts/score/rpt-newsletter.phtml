	function displaymonth() {
		exam_type = dijit.byId('exam_type').get('value');
		if (exam_type == 1) {
			$("#semester").css("display", "none");
			$("#month").css("display", "block");
		} else {
			$("#semester").css("display", "block");
			$("#month").css("display", "none");
		}
	}
</script>