								template+='<td ><?php echo $tr->translate("GROUP_CODE");?></td>';
							template+='</tr>';
						template+='</thead>';
			
			for(var i=0;i<jsonArray.length;i++) {
				no++;
				template+='<tr class=" hover" >';
					template+='<td align="center">'+no+'</td>';
					template+='<td align="center">';
					template+=jsonArray[i].code;
					template+='</td>';
					template+='<td >'+jsonArray[i].nameKh+'</td>';
					template+='<td align="center">'+jsonArray[i].gCode+'</td>';
					
				template+="</tr>";
				
			}
			template+="</table>";
			$("#contentDetailPop").html(template);
			dijit.byId("popupStudentInfo").show();
		}else{
			$(".studentCode").html($("#studentCode"+index).html());
			template='';
			var no = 0;
			var identity ="";
			template+='<table class="content-data bd-dark-grey text-color-black text-h16px text-size-12px" border="1" cellspacing="5" width="100%">';
						template+='<thead  id="head-title" >';
							template+='<tr class="styleheader bg-head text-bold hpx-20" align="center">';
								template+='<td width="4%" ><?php echo $tr->translate("NO");?></td>';
								template+='<td ><?php echo $tr->translate("TELEGRAM_ACCOUNT");?></td>';
								template+='<td ><?php echo $tr->translate("JOIN_DATE");?></td>';
