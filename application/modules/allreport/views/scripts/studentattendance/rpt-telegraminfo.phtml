function showDetailInfo(index,type=1){
	var jsData = dijit.byId('jsData'+index).get('value');
	var jsonArray = JSON.parse(jsData);
	
	if(jsonArray.length>0){
		if(type==1){
			$(".studentCode").html($("#accName"+index).html());
			template='';
			var no = 0;
			var identity ="";
			template+='<table class="content-data bd-dark-grey text-color-black text-h16px text-size-12px" border="1" cellspacing="5" width="100%">';
						template+='<thead  id="head-title" >';
