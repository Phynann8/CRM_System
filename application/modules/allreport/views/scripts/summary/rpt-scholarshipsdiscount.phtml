								$grandTotalStudent = 0;
								$grandTotalValue = 0;
								foreach ($grouped as $branch => $rows) {
									$rowspan = count($rows);
									$branchTotalStudent = 0;
									$branchTotalValue = 0;

									foreach ($rows as $index => $rs) {
