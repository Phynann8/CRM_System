											echo '<td rowspan="' . $rowspan . '" align="center" style="vertical-align: middle;">' . $branch . '</td>';
										}
										echo '
											<td align="left">' . $rs['DiscountType'] . '</td>
											<td align="left">' . (!empty($rs['DisCode']) ? $rs['DisCode'] : '&nbsp;') . '</td>
