				 				backgroundColor: null,
				 			}).then(canvas => {
				 				let imgData = canvas.toDataURL("image/png");
				 				let imgWidth = 794;
				 				let imgHeight = (canvas.height * imgWidth) / canvas.width;

				 				// Add transparent background
				 				doc.addImage(transparentBg, 'PNG', xOffset, yOffset, bgWidth, bgHeight);

				 				// Add section content
				 				doc.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight);

				 				if (index < sections.length - 1) {
				 					doc.addPage();
				 				}

				 				processSection(index + 1); // Process next section
				 			});
				 		};
				 		processSection(0);
				 	};
				 });

function dataURItoBlob(dataURI) {
    let byteString = atob(dataURI.split(',')[1]); // Decode Base64
    let mimeString = dataURI.split(',')[0].split(':')[1].split(';')[0]; // Extract MIME type

    let arrayBuffer = new ArrayBuffer(byteString.length);
    let uint8Array = new Uint8Array(arrayBuffer);
    for (let i = 0; i < byteString.length; i++) {
        uint8Array[i] = byteString.charCodeAt(i);
    }

    return new Blob([uint8Array], { type: mimeString });
}
function supportFile (){
    return typeof window.Blob !== "undefined" &&
            typeof window.ArrayBuffer !== "undefined" &&
            typeof window.Uint8Array !== "undefined" &&
            typeof window.atob !== "undefined";
}

function upload(base64String){
    if(!supportFile()){
        alert("don't support")
        return;
    }
	
	let formData = new FormData();
	let fileBlob = dataURItoBlob(base64String);
	formData.append('file', fileBlob, "<?php echo $fileName; ?>");

    var url = "<?PHP echo $this->baseUrl()."/api/index/uploaddata";?>";
	$.ajax({
        url: url,
		cache: false,
		method: 'POST',
		type: 'POST',
		data: formData,
		contentType: false, 
		processData: false,
		success: function(response) {
			if(response!= ""){
				window.open('<?php echo $this->baseUrl();?>/images/document/tmp/'+response, '_self');
			}
		},
		error: function(xhr, status, error) {
			console.error('Upload Failed:', error);
		}
     });
}
