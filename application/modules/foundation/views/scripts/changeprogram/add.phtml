		temp_student+='<th ><?php echo $tr->translate("GRADE");?></th>';
		temp_student+='<th ><?php echo $tr->translate("GROUP");?></th>';
		dojo.query("#head-title_student").append(temp_student);
		title_student=1;
	}
		template_student+='<td width="4%"align="center"><img onclick="deleteRecordStudent('+col_student+')" src="<?php echo $this->baseUrl();?>/images/Delete_16.png"></td>';
