function getProgramTypeList(type=0) {
	let urlGetProgramList = '<?php echo $this->url(array('module' => 'global', 'controller' => 'programtype', 'action' => 'get-program-list')); ?>';
	var thisIsSingleProgram="";
	if(type==1){
		thisIsSingleProgram = $('#isSingleProgram').val();
	}
	contentData = {
		'option':1,
		'isNotThisOpt':thisIsSingleProgram,
	}
	dojo.xhrPost({
		url: urlGetProgramList,
		content:contentData,
		handleAs:"json",
		load: function(data){
			if(type==1){
				$('#toProgramType').empty().trigger("change");
				$('#toProgramType').append(data).trigger('change');
			}else{
				$('#programType').empty().trigger("change");
				$('#programType').append(data).trigger('change');
			}
			
		},
		error: function(err) {
		}
	});
}
function getProgramInfo(type=0){
	if(type==1){
		var programType = $('#toProgramType').find(":selected").val();
		if(typeof programType !=="undefined" ){
			if( programType >0){
				var programTypeInfo = ($("#toProgramType").find(':selected').data('record-info'));
				if(programTypeInfo !="undefined" ){
					$('#isSingleToProgram').val(programTypeInfo.isSingleProgram);
				}
			}
		}
	}else{
		var programType = $('#programType').find(":selected").val();
		if(typeof programType !=="undefined" ){
			if( programType >0){
				var programTypeInfo = ($("#programType").find(':selected').data('record-info'));
				if(programTypeInfo !="undefined" ){
					$('#isSingleProgram').val(programTypeInfo.isSingleProgram);
				}
			}
		}
		getProgramTypeList(1);
	}
	checkingProgramInfo(type);
	
}

function checkingProgramInfo(type=0){
	if(type==1){
		var isSingleToProgram = $('#isSingleToProgram').val();
		if(isSingleToProgram==1){
			$("div.subClassInfo").addClass("d-none");
			$('#identity_study').val("");
			$('#table_row_study').html("");
		}else{
			$("div.subClassInfo").removeClass("d-none");
		}
	}
}

url_getallgroup = '<?php echo $this->url(array('module'=>'foundation','controller'=>'group','action'=>'getallgroup'));?>';
function getAllGroup(type=0){
	
	branch_id = dijit.byId('branch_id').get('value');
	if(branch_id=='' || branch_id==-1){
		var group_store  = getDataStorefromJSON('id','name',<?php print_r(Zend_Json::encode(array()));?> );
		if(type==1){
			dijit.byId('groupAddRow').set('store',group_store);   
		}else{
			dijit.byId('group').set('store',group_store);   
		}  
		dijit.byId('branch_id').focus();
		return false;
	}
	degree = dijit.byId('degree').get('value');
	if(degree=='' || degree==-1){
		degree ="";
	}
	
	grade = dijit.byId('grade').get('value');
	if(grade=='' || grade==-1){
		grade ="";
	}
	if(type==1){
		degree = dijit.byId('degreeAddRow').get('value');
		grade = dijit.byId('gradeAddRow').get('value');
		dijit.byId('groupAddRow').reset();  
	}else{
		dijit.byId('group').reset();  
	}
	dojo.xhrPost({
		url: url_getallgroup,
		content:{
			'branch_id':branch_id,
			'degree':degree,
			'grade':grade,
			'noaddnew':1
		},
		handleAs:"json",
		load: function(data) {
		    group_store  = getDataStorefromJSON('id','name', data); 
			if(type==1){
				dijit.byId('groupAddRow').set('store',group_store);   
			}else{
				dijit.byId('group').set('store',group_store);   
			}			
		},
		error: function(err) {
		}
	});
}
function getRefreshItems(type=0){
	var degreeList = "";
	if(type==1){
		dijit.byId('degreeAddRow').reset();  
		degreeList = $('#toDegreeList').val();
	}else{
		degreeList = $('#degreeList').val();
		dijit.byId('degree').reset();  
	}
	var url_getItems = '<?php echo $this->url(array("module"=>"global","controller"=>"degree","action"=>"refreshitems"));?>';										
	dojo.xhrPost({
		url: url_getItems,
		content:{
			'items_type': 1,
			'degreeList': degreeList,
			},
		handleAs:"json",
		load: function(data) {
			degree_store  = getDataStorefromJSON('id','name', data);
			if(type==1){
				dijit.byId('degreeAddRow').set('store',degree_store);
			}else{
				dijit.byId('degree').set('store',degree_store);
			}
		    HideloadingBlock();
		},
		error: function(err) {
			HideloadingBlock();
		}
	});
}
