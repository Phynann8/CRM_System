		template_study+='<td width="4%" align="center">'+no_study+'</td>';
		template_study+='<td>&nbsp;<input style="width:100%;" placeholder="<?php echo $tr->translate("DEGREE");?>" dojoType="dijit.form.TextBox" class="fullside" name="degree_'+col_study+'" id="degree_'+col_study+'" value="'+degreeAddRow+'" type="hidden">'+degreelabel+'&nbsp;</td>';
		template_study+='<td>&nbsp;<input style="width:100%;" placeholder="<?php echo $tr->translate("GRADE");?>" dojoType="dijit.form.TextBox" class="fullside" name="grade_'+col_study+'" id="grade_'+col_study+'" value="'+gradeAddRow+'" type="hidden">'+gradelabel+'&nbsp;</td>';
		template_study+='<td>&nbsp;<input style="width:100%;" placeholder="<?php echo $tr->translate("GROUP");?>" dojoType="dijit.form.TextBox" class="fullside" name="group_'+col_study+'" id="group_'+col_study+'" value="'+groupAddRow+'" type="hidden">'+groupabel+'&nbsp;</td>';
		
	tmp_study='<tr id="row_study'+col_study+'">';
	tmp_study+="</tr>";
	dojo.query("#table_row_study").append(tmp_study);

	if($("#identity_study").val()!="") {
		var identity_study = $("#identity_study").val();
		$("#identity_study").val(identity_study+','+col_study);
	} else {$("#identity_study").val(col_study);}
	dojo.html.set(dojo.byId("row_study"+col_study),template_study , {
		 parseContent: true,
	});
	dijit.byId('degreeAddRow').reset();
	dijit.byId('gradeAddRow').reset();
	dijit.byId('groupAddRow').reset();
}
function deleteRecord_study(index) {
	var identity = $('#identity_study').val();
	var arrays = identity.split(',');
	for(var i=0;i<arrays.length;i++) {
	if(arrays[i] == index) arrays.splice(i,1);
	}
	var strings = arrays.join(',');
	$('#identity_study').val(strings);
	dojo.query("#row_study"+index).remove();
}


var col_student = 0;
var no_student = 0;
var title_student = 0;
tmp_student= '';
temp_student='';
function addRowStudent() {
	
	let stuCode = "";
	let stuName = "";
	let degreeLabel = "";
	let gradeLabel = "";
	let groupLabel = "";
	let currentStudentId = 0;
	let thisDegree= "";
	let thisGrade = "";
	let thisGroup = "";
	var studentId = $('#studentId').find(":selected").val();
	if(typeof studentId !=="undefined" ){
		if( studentId >0){
			currentStudentId = studentId;
			var recordInfo = ($("#studentId").find(':selected').data('record-info'));
			if(recordInfo !="undefined" ){
				stuCode = recordInfo.studentCode;
				stuName = recordInfo.studentNameKh;
				degreeLabel = recordInfo.degreeTitle;
				gradeLabel = recordInfo.gradeTitle;
				groupLabel = recordInfo.groupCode;
				
				thisDegree = recordInfo.degree;
				thisGrade = recordInfo.grade;
				thisGroup = recordInfo.groupId;
			}
			$("#studentId").val(null).trigger("change"); 
		}
	}
	
	if(currentStudentId==0){
		return false;
	}
	var alreadySeleted= false;
	var identityStudent = $('#identity_student').val();
	var arrayStu = identityStudent.split(',');
	if(identityStudent!=""){
		for (var p = 1; p <= arrayStu.length; p++) {
			var thisRow = dijit.byId('studentId'+p).get('value');
			if(thisRow==currentStudentId){
				alreadySeleted = true;
				break;
			}
		}
	}
	if(alreadySeleted){
		alert("<?php echo $tr->translate("ALREADY_SELECTED");?>");
		return false;
	}
	
	
	
