					 dijit.byId('gradeAddRow').set('store',grade_store);   
				}else{
					 dijit.byId('grade').set('store',grade_store);   
				}
			},
			error: function(err) {
			}
		});
}

var urlGetData = '<?php echo $this->url(array('module' => 'setting', 'controller' => 'photomg', 'action' => 'get-record-list')); ?>';
function getStudentOption(){
	
	var recordType = 1;
	branchId = dijit.byId("branch_id").get("value");
	if (branchId == '') {
		//dijit.byId("branchId").focus();
		return false;
	}
	var currentProgramType = 0;
	var programType = $('#programType').find(":selected").val();
	if(typeof programType !=="undefined" ){
		if( programType >0){
			currentProgramType = programType;
		}
	}
	academicYear = dijit.byId('academicYear').get('value');
	degree = dijit.byId('degree').get('value');
	grade = dijit.byId('grade').get('value');
	
	dojo.xhrPost({
		url: urlGetData,
		content: {
			'branchId': branchId
			,'recordType': recordType
			,'joinGroup': 1
			,'itemType': 1
			,'isMaingrad': 1
			,'isCurrent': 1
			,'activStudent': 1
			,'customerType': 1
			,'option': 1
			,'programType': currentProgramType
			,'academicYear': academicYear
			,'degree': degree
			,'grade': grade
			
		},
		handleAs: "json",
		load: function (data) {
			$('#studentId').empty().trigger("change");
			$('#studentId').append(data).trigger('change');
		},
		error: function (err) {
		}
	});
}

