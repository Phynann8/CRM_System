function loadImage(url, elem) {
    checkImage(url, function(ok) {
        if (!ok) {
            elem.attr("src", '<?php echo $defaultProfile;?>');
        } else {
            elem.attr("src", url);
        }
    });
}
function checkImage(url, callback) {
    var img = new Image();
    img.onload = function () { callback(true); };
    img.onerror = function () { callback(false); };
    img.src = url;
}  
  
/* Generate SVG QR using qrcode-generator lib */
function generateSvgQR(text) {
  var qr = qrcode(0, "M");
  qr.addData(text);
  qr.make();
  return qr.createSvgTag(4, 10); // scale = 4
}
/* escape HTML to avoid injection */
function escapeHtml(s) {
  return (s + "").replace(/[&<>"]/g, function (m) {
    return ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      "\"": "&quot;"
    })[m];
  });
}

