<script>

const rows = <?php echo json_encode($this->rs);?>;

    function todayStr(){const d=new Date();return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`}

    const orientation = document.getElementById('orientation');
   
    const rebuildBtn = document.getElementById('rebuild');
    const viewer11 = document.getElementById('viewer');
    const prevBtn = document.getElementById('prevPage');
    const nextBtn = document.getElementById('nextPage');
    const pageIndicatorII = document.getElementById('pageIndicator');
	let orientationValue = 'portrait';
	let initialRowsPerPage = 45;

    const zoomPercent = document.getElementById('zoomPercent');
    function setScale(s){ s = Math.max(0.4, Math.min(2, s)); document.documentElement.style.setProperty('--sheet-scale', String(s)); zoomPercent.textContent = Math.round(s*100) + '%' }
    function getScale(){ return Number(getComputedStyle(document.documentElement).getPropertyValue('--sheet-scale')) || 1 }
    document.getElementById('zoomIn').addEventListener('click', ()=>setScale(getScale()+0.1));
    document.getElementById('zoomOut').addEventListener('click', ()=>setScale(getScale()-0.1));
    document.getElementById('zoomReset').addEventListener('click', ()=>setScale(1));

    const pageStyle = document.createElement('style'); document.head.appendChild(pageStyle);
    function updatePageStyle(){ 
		const m = 12; 
		const orient = orientationValue; 
		pageStyle.textContent = `@page{size:A4 ${orient};margin:${m}mm}`;
		
	}

    let totalPagesII = 0;
    let currentPageII = 1;
    let indexRow = 0;
	
    function makeTableHTML(rowsSubset){
  let html = `<table width="100%" class="content-data-main text-color-black text-h12px text-size-9px bd-dark-grey" cellpadding="2" border="1" >
										<thead>
											<tr style="white-space:nowrap;" class="style-head bd-black bd-w1px style-head bg-head hpx-25" align="center" >
												<th class="text-center w-px-30" rowspan="2"><?php echo $tr->translate("NUM");?></th>
												<th class="text-center" rowspan="2"><?php echo $tr->translate("BRANCH_NAME");?></th>
												<th class="text-center" colspan="6"><?php echo $tr->translate("STUDENT_INFO");?></th>

												<th class="text-center" colspan="3"><?php echo $tr->translate("STUDY_INFO");?></th>
												<th class="text-center" colspan="6"><?php echo $tr->translate("PARENT_INFO");?></th>
												<th class="text-center w-px-80" rowspan="2"><?php echo $tr->translate("CURRENT_ADDRESS");?></th>	
												<th class="text-center w-px-60" rowspan="2" ><?php echo $tr->translate("CONTACT_NO");?></th>				
												<th class="text-center" rowspan="2"><?php echo $tr->translate("STATUS");?></th>
											</tr>
											<tr style="white-space:nowrap;" class="style-head bd-black bd-w1px style-head bg-head hpx-25 " align="center" >

												<th class="text-center" ><?php echo $tr->translate("STUDENT_ID");?></th>
												<th class="text-center" ><?php echo $tr->translate("STUDENT_NAMEKHMER");?></th>
												<th class="text-center" ><?php echo $tr->translate("NAME_ENGLISH");?></th>
												<th class="text-center" ><?php echo $tr->translate("SEX");?></th>
												<th class="text-center" ><?php echo $tr->translate("NATIONALITY");?></th>
												<th class="text-center" ><?php echo $tr->translate("DATE_OF_BIRTH");?></th>

												<th class="text-center"><?php echo $tr->translate("DEGREE");?></th>
												<th class="text-center w-px-70"><?php echo $tr->translate("GRADE");?></th>
												<th class="text-center"><?php echo $tr->translate("SESSION");?></th>

												<th class="text-center w-px-70"><?php echo $tr->translate("FATHER_NAME");?></th>
												<th class="text-center w-px-60"><?php echo $tr->translate("OCCUPATION");?></th>
												<th class="text-center w-px-60"><?php echo $tr->translate("CONTACT_NO");?></th>											
												<th class="text-center w-px-70"><?php echo $tr->translate("MOTHER_NAME");?></th>
												<th class="text-center w-px-60"><?php echo $tr->translate("OCCUPATION");?></th>
												<th class="text-center w-px-60"><?php echo $tr->translate("CONTACT_NO");?></th>	
											</tr>											
										</thead>
    <tbody>`;
  rowsSubset.forEach(r => {
	  
			indexRow++;								
    html += `<tr>
      <td>${indexRow}</td>
      <td>${r.branch_name}</td>
      <td>${r.stu_code}</td>
      <td>${r.stu_khname}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
      <td style="text-align:right">${r.nationality}</td>
    </tr>`;
  });
  html += '</tbody></table>';
  html += `<div class="signFooter"><?php echo $this->rsfooteracc;?></div>`;
  return html;
}

function buildPages(){indexRow = 0;
  viewer11.innerHTML = '';
  const frag = document.createDocumentFragment(); // append all at once

  const orientClass = orientationValue === 'landscape' ? 'landscape' : 'portrait';
  const rowsPerPage = initialRowsPerPage; // adjust if needed
  const totalPageCount = Math.ceil(rows.length / rowsPerPage);

  for (let i = 0; i < totalPageCount; i++){
    const subset = rows.slice(i * rowsPerPage, (i + 1) * rowsPerPage);

    const wrapper = document.createElement('div');
    wrapper.className = `sheet a4 ${orientClass} ${i === 0 ? 'active' : ''}`;

    // header
    const hdr = $('#headerTpl')[0].content.firstElementChild.cloneNode(true);
     wrapper.appendChild(hdr);

    // content
    const pageContent = document.createElement('div');
    pageContent.className = 'page-content';
    pageContent.innerHTML = makeTableHTML(subset); // <-- optimized
    wrapper.appendChild(pageContent);

    // footer
    const ftr = $('#footerTpl')[0].content.firstElementChild.cloneNode(true);
    ftr.querySelector('[data-bind="page"]').textContent = i + 1;
    ftr.querySelector('[data-bind="pages"]').textContent = totalPageCount;
    wrapper.appendChild(ftr);

    frag.appendChild(wrapper);
  }
	setTimeout(function() {
		let headerHeight=$('.page-header').height();
			$(".page-content").css("top", headerHeight);
	}, 500);
  viewer11.appendChild(frag);

  totalPagesII = totalPageCount;
  currentPageII = 1;
  updateActivePage();
}

    function updateActivePage(){
      const pages = viewer11.querySelectorAll('.sheet');
      pages.forEach((p,i)=> p.classList.toggle('active', i === currentPageII-1));
	  $("#pageIndicatorValue").val(currentPageII);
      pageIndicatorII.textContent = ` / ${totalPagesII}`;
      prevBtn.disabled = currentPageII === 1;
      nextBtn.disabled = currentPageII === totalPagesII;
    }

    prevBtn.addEventListener('click', ()=>{ if(currentPageII>1){ currentPageII--; updateActivePage(); }});
    nextBtn.addEventListener('click', ()=>{ if(currentPageII<totalPagesII){ currentPageII++; updateActivePage(); }});

	document.getElementById('portraitBtn').onclick = () => {
		orientationValue = 'portrait';
		initialRowsPerPage=45;
		buildPages(); updatePageStyle();
	};
	document.getElementById('landscapeBtn').onclick = () => {
		orientationValue = 'landscape';
		initialRowsPerPage=25;
		buildPages(); updatePageStyle();
		
	};
   
    rebuildBtn.addEventListener('click', buildPages);

    setScale(1);
    updatePageStyle();
    buildPages();
  </script>