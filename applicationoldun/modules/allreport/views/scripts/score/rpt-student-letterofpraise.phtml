	function checkAllStudent(array_length) {
		const idSelected = document.getElementById('id_selected');
		idSelected.value = ''; // Reset selection

		const checkAll = document.getElementById('checkall').checked;
		let selectedIds = [];

		for (let j = 1; j <= array_length; j++) {
			const checkbox = document.getElementById(`check_box${j}`);
			const letterpraiseInput = dijit.byId(`letterpraise_id${j}`);
			if (!checkbox || !letterpraiseInput) continue;

			checkbox.checked = checkAll;

			if (checkAll) {
				selectedIds.push(letterpraiseInput.get('value'));
			}
		}

		idSelected.value = selectedIds.join(',');
	}

	function updateSelectedIds(index) {
		const checkbox = document.getElementById(`check_box${index}`);
		const letterpraiseInput = dijit.byId(`letterpraise_id${index}`);
		if (!checkbox || !letterpraiseInput) return;

		const letterpraiseId = letterpraiseInput.get("value");
		const idSelected = document.getElementById('id_selected');

		let selectedIds = idSelected.value ? idSelected.value.split(",") : [];

		if (checkbox.checked) {
			if (!selectedIds.includes(letterpraiseId)) {
				selectedIds.push(letterpraiseId);
			}
		} else {
			selectedIds = selectedIds.filter(id => id !== letterpraiseId);
		}

		idSelected.value = selectedIds.join(",");
	}

	// Attach event listeners to all checkboxes dynamically
	document.addEventListener("DOMContentLoaded", function () {
		document.querySelectorAll("[id^='check_box']").forEach(checkbox => {
			checkbox.addEventListener("change", function () {
				const index = this.id.replace("check_box", "");
				updateSelectedIds(index);
			});
		});
	});


