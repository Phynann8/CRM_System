<?php
require_once 'dompdf/autoload.inc.php'; // Update the path if necessary

use Dompdf\Dompdf;
use Dompdf\Options;

// Set Dompdf options
$options = new Options();
$options->set('isHtml5ParserEnabled', true);
$options->set('isPhpEnabled', true);
// $options->set('defaultFont', 'KH-BATTAMBANG');
// $options->set('isFontSubsettingEnabled', true);


$dompdf = new Dompdf($options);

// Register Khmer fonts manually

// HTML content with Khmer text
$html = '
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <style>
      
        @font-face {
            font-family: "KhmerOSMuol";
            src: url("KhmerOSMuol.ttf") format("truetype");
        }
        body {
            font-family: "KH-BATTAMBANG", sans-serif;
        }
        .title {
            font-family: "KhmerOSMuol", sans-serif;
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }
    </style>
</head>
<body>
    <h1>Hello world</h1>
    <p>សួស្តី! នេះជាឯកសារ PDF ដែលប្រើអក្សរកម្ពុជា។</p>
    <p class="title">ជំរាបសួរ!</p>
</body>
</html>';

// Load HTML into Dompdf
$dompdf->loadHtml($html);
$dompdf->setPaper('A4', 'portrait');
$dompdf->render();

// Stream the PDF
$dompdf->stream("Khmer_PDF", array("Attachment" => 0));
?>
