	function setValue(total){
		var identityArr = [];
		var studentIdArr = [];

		for (var j = 1; j <= total; j++) {
			var checkbox = dojo.byId('checkbox' + j);
			if (checkbox && checkbox.checked) {

				// store row index
				identityArr.push(j);

				// store real student id
				var stuId = $('#stu_id_' + j).val();
				if (stuId) {
					studentIdArr.push(stuId);
				}
			}
		}

		$('#identity').val(identityArr.join(','));
		$('#student_ids').val(studentIdArr.join(','));
	}


	function check(total){
		var isChecked = $('#checkall').is(':checked');

		for (var j = 1; j <= total; j++) {
			var checkbox = dojo.byId('checkbox' + j);
			if (checkbox) {
				checkbox.checked = isChecked;
			}
		}

		setValue(total);
	}


