			store: staff_store,
			queryExpr: "*${0}*",
			autoComplete: false,
			required: true,
			id: "staff_id",
			name: "staff_id",
			class: 'fullside',
			required: false,
			placeHolder: "<?php echo $tr->translate("SELECT_STAFF_NAME"); ?>",
			onChange: function () {

				staff_id = dijit.byId('staff_id').get('value');
				branch_id = dijit.byId('branch1').get('value');
