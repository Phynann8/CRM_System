			store: stu_store,
			queryExpr: "*${0}*",
			autoComplete: false,
			required: true,
			id: "stu_id",
			name: "stu_id",
			class: 'fullside',
			required: false,
			placeHolder: "<?php echo $tr->translate("SELECT_STUDENT_NAME"); ?>",
			onChange: function () {

				stu_id = dijit.byId('stu_id').get('value');
				branch_id = dijit.byId('branch').get('value');
				if (stu_id == '') {
					
					return false;
				} else {
					var rowId = $('#identity').val();
					if (rowId != '') {
						var rowIDArray = rowId.split(',');
