					alert("please select staff name");
					return false;
				} else {
					var rowId = $('#identity1').val();
					if (rowId != '') {
						var rowIDArray = rowId.split(',');
						for (var n = 0; n < rowIDArray.length; n++) {
							var staff_name = dijit.byId('staff_name_' + rowIDArray[n]).get('value');


						}
