							var student_name = dijit.byId('student_name_' + rowIDArray[n]).get('value');
						}
					}
					addRow();

				}

			}
		}, "stu_id");

		new dijit.form.FilteringSelect({
			store: group_store,
			queryExpr: "*${0}*",
			autoComplete: false,                     
			id: "group",
			name: "group",  
			class: 'fullside', 
