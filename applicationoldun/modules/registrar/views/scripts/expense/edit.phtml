	function checkValidateAddRow() {
		var rowId = $('#identity').val();
		if (rowId != '') {
			var rowIDArray = rowId.split(',');
			for (var n = 0; n < rowIDArray.length; n++) {
				expense = dijit.byId('expense_id_' + rowIDArray[n]).get('value');
				if (expense <= 0) {
					return false;
				}
			}
		}
	}

