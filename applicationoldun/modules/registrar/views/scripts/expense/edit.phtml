		if (expense_id == -1) {
			dijit.byId("popup_cate_expense").show();
		}else if(expense_id !=''){
			// get old price 
			dojo.xhrPost({
				url:url_expense,
				content:{
					'expense_id':expense_id,
					'sup_id':sup_id
