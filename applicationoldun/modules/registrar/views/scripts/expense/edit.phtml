	var url_add_cate_expense = '<?php echo $this->url(array("module" => "registrar", "controller" => "expense", "action" => "add-cate-expense")); ?>';

	function addCateExpense() {
		if (dijit.byId('add_cate_expense').validate()) {
			dijit.byId("ex_save_new").attr("disabled", true);
			dojo.xhrPost({
				url: url_add_cate_expense,
				form: dojo.byId("add_cate_expense"),
				handleAs: "json",
				load: function(data) {
					var Itemmake = {
						id: data.id,
						name: dijit.byId('account_name').get('value')
					};
					index = $("#tow_value").val();
					addDataToSelectbox(dijit.byId('expense_id_' + index), cate_expense_store, Itemmake, data.id);
					optexpense = data.new_array;
					dijit.byId('add_cate_expense').reset();
					dijit.byId("popup_cate_expense").hide();
				},
				error: function(err) {
					alert(err);
				}
			});
		}
	}

	function filterSubCategory(){
		var datajson = $('#parentcategory').find(":selected").val();
		dijit.byId("category").attr('value','');
		dijit.byId("itemId").attr('value','');
		if(typeof datajson !=="undefined" ){
			var datajsonparent = ($("#parentcategory").find(':selected').data('jsondata'));
			subcategorystore = getDataStorefromJSON('id', 'name', datajsonparent);
			dijit.byId('category').set('store', subcategorystore);
		}
		getExpenseItem();
	}

	function getExpenseItem(){
		categoryId=dijit.byId("category").get("value");
		parentId = $('#parentcategory').val();
		var urlGet = '<?php echo $this->url(array('module'=>'registrar','controller'=>'cateexpense','action'=>'get-expenseitem')); ?>';
		contentData = {
			'parentId':parentId,
			'categoryId':categoryId,
			'addNew':1,
		}
		dojo.xhrPost({
			url:urlGet,	
			handleAs:"json",
			content:contentData,
			load: function(data) {
				itemstoreorg = data;
				exp_itemstore  = getDataStorefromJSON('id','name', data);		
				dijit.byId('itemId').set('store',exp_itemstore);  
			},
			error: function(err){
			}
		});
	}

